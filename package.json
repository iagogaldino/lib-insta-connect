{
  "name": "lib-insta-connect",
  "version": "0.1.0",
  "description": "Biblioteca para automacao de interacoes com Instagram via Puppeteer",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/example.js",
    "dev": "nodemon",
    "socket": "node dist/socket-server.js",
    "socket:dev": "nodemon --exec ts-node src/socket-server.ts",
    "socket:client": "node dist/socket-client.js",
    "socket:client:dev": "ts-node src/socket-client.ts",
    "build:userscript": "ts-node scripts/build-userscript.ts"
  },
  "keywords": [
    "instagram",
    "crawler",
    "puppeteer",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.2.3",
    "puppeteer": "^24.6.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
